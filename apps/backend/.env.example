NODE_ENV=development
PORT=3000
LOG_LEVEL=info

DATABASE_PATH=./data/garden-guide.db
PHOTO_DIR=./data/photos

SESSION_SECRET=change-me-to-a-long-random-string-of-32-plus-chars
PUBLIC_URL=http://localhost:3000

# LLM provider — `openai` (default) or `anthropic`. Only the selected
# provider's key is required at startup.
LLM_PROVIDER=openai
# Optional override; falls back to a sensible default per provider
# (gpt-4o for openai, claude-3-5-sonnet-latest for anthropic).
# LLM_MODEL=

OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
